{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schema/map-intent-0.1.json",
  "title": "RPG Maker MZ Map Intent",
  "type": "object",
  "additionalProperties": false,
  "required": ["map_id", "seed", "map_type", "biome", "width", "height", "tileset_profile", "theme", "traversal_style", "entrances", "exits", "required_pois", "districts", "boundary_type", "path_style", "constraints", "forbidden_patterns", "event_hooks", "region_painting_rules"],
  "properties": {
    "map_id": { "type": "string", "minLength": 1 },
    "seed": { "type": ["integer", "string"] },
    "map_type": { "enum": ["town", "interior", "dungeon", "overworld_submap", "shrine", "castle"] },
    "biome": { "type": "string", "minLength": 1 },
    "width": { "type": "integer", "minimum": 12, "maximum": 200 },
    "height": { "type": "integer", "minimum": 10, "maximum": 200 },
    "tileset_profile": { "type": "string", "minLength": 1 },
    "theme": { "type": "string" },
    "traversal_style": { "enum": ["hub_and_spoke", "loop", "branching", "linear", "rooms_and_corridors"] },
    "entrances": { "$ref": "#/$defs/portList" },
    "exits": { "$ref": "#/$defs/portList" },
    "required_pois": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/poi" } },
    "optional_pois": { "type": "array", "default": [], "items": { "$ref": "#/$defs/poi" } },
    "districts": { "type": "array", "items": { "$ref": "#/$defs/district" } },
    "boundary_type": { "enum": ["open", "forest", "cliff", "water", "wall", "interior_wall"] },
    "path_style": { "type": "object", "required": ["semantic", "width"], "properties": { "semantic": { "enum": ["road", "interior_floor", "sand"] }, "width": { "type": "integer", "minimum": 1, "maximum": 5 }, "meander": { "type": "number", "minimum": 0, "maximum": 1 } }, "additionalProperties": false },
    "required_landmarks": { "type": "array", "default": [], "items": { "type": "string" } },
    "constraints": { "type": "object", "properties": { "allowed_building_dimensions": { "type": "array", "items": { "type": "array", "prefixItems": [{"type":"integer"},{"type":"integer"}], "minItems": 2, "maxItems": 2 } }, "max_empty_ratio": { "type": "number", "minimum": 0, "maximum": 1 }, "allow_walkable_islands": { "type": "boolean" } }, "additionalProperties": true },
    "forbidden_patterns": { "type": "array", "items": { "type": "string" } },
    "event_hooks": { "type": "array", "items": { "$ref": "#/$defs/eventHook" } },
    "region_painting_rules": { "type": "array", "items": { "type": "object", "required": ["semantic", "region_id", "purpose"], "properties": { "semantic": { "type": "string" }, "region_id": { "type": "integer", "minimum": 1, "maximum": 255 }, "purpose": { "type": "string" } }, "additionalProperties": false } }
  },
  "$defs": {
    "position": { "type": "object", "required": ["side", "offset"], "properties": { "side": { "enum": ["north", "south", "east", "west"] }, "offset": { "type": "integer", "minimum": 1 } }, "additionalProperties": false },
    "portList": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "position"], "properties": { "id": { "type": "string" }, "position": { "$ref": "#/$defs/position" }, "target": { "type": "string" } }, "additionalProperties": false } },
    "poi": { "type": "object", "required": ["id", "kind"], "properties": { "id": { "type": "string" }, "kind": { "type": "string" }, "district": { "type": "string" }, "size": { "type": "array", "prefixItems": [{"type":"integer"},{"type":"integer"}], "minItems": 2, "maxItems": 2 }, "focal": { "type": "boolean" } }, "additionalProperties": false },
    "district": { "type": "object", "required": ["id", "role"], "properties": { "id": { "type": "string" }, "role": { "type": "string" }, "contains": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
    "eventHook": { "type": "object", "required": ["id", "kind", "at"], "properties": { "id": { "type": "string" }, "kind": { "enum": ["npc", "treasure", "transfer", "interactable", "shopkeeper", "innkeeper"] }, "at": { "type": "string" }, "payload": { "type": "object" } }, "additionalProperties": false }
  }
}
