{
  "$id": "generation_manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenerationManifest",
  "description": "Provenance and deterministic-seed record for one compiler run: which MapIntent, BuildingArchetype version, LayoutFamily version/variant, StylePack version, and (optionally) TilePalette version produced which MapPlan, and exactly how the seed was derived. See contract/README.md 'Seed Derivation' for the algorithm this record's `seed` object must satisfy.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "map_intent_ref", "generator_ref", "adapter_ref", "archetype_ref", "layout_family_ref", "style_pack_ref", "seed", "contract_version", "generated_at", "status"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1"] },
    "manifest_id": { "type": "string", "pattern": "^GEN-[A-Za-z0-9_.-]+$" },
    "map_intent_ref": { "type": "string" },
    "generator_ref": {
      "description": "Reusable compiler implementation and exact version used for this run.",
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_id", "version"],
      "properties": {
        "generator_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "adapter_ref": {
      "description": "Engine adapter selected for this run. Null while the output remains engine-neutral.",
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "archetype_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype_id", "version"],
      "properties": {
        "archetype_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "layout_family_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout_family_id", "version", "variant_id"],
      "properties": {
        "layout_family_id": { "type": "string" },
        "version": { "type": "string" },
        "variant_id": { "type": "string" }
      }
    },
    "style_pack_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style_pack_id", "version"],
      "properties": {
        "style_pack_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "tile_palette_ref": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "tile_palette_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "inputs", "salt", "value"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["sha256_truncated_64"] },
        "inputs": {
          "description": "Ordered list of the exact string components hashed, in order, joined with '|' before hashing.",
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "salt": { "type": "string" },
        "value": { "type": "integer", "minimum": 0 }
      }
    },
    "contract_version": { "type": "string", "enum": ["0.1"] },
    "generated_at": { "type": "string" },
    "output_map_plan_ref": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["generated_pending_review", "accepted", "accepted_with_notes", "rejected"] },
    "map_vision_ref": {
      "description": "WO-0071: version-pinned MapVision this run resolved visual constraints from. Optional and null for runs outside the visual pipeline; existing 0.1 manifests remain valid without it.",
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["map_vision_id", "version"],
      "properties": {
        "map_vision_id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "tile_assembly_bindings": {
      "description": "WO-0071: one entry per semantic tag bound to a catalog-enabled TileAssembly/custom-extension asset during this run. Optional and empty for runs outside the visual pipeline.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["semantic_tag", "tile_assembly_id", "tile_assembly_source_kit", "review_state", "adapter_ref", "width", "height", "building_height_rows"],
        "properties": {
          "semantic_tag": { "type": "string" },
          "tile_assembly_id": { "type": "string" },
          "tile_assembly_source_kit": { "type": "string" },
          "review_state": { "type": "string" },
          "adapter_ref": { "type": "string" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "building_height_rows": { "type": ["integer", "null"], "minimum": 1 }
        }
      }
    }
  }
}
