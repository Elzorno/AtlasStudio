{
  "$id": "tile_assembly.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TileAssembly",
  "description": "A versioned, source-pinned rectangular tile assembly extracted for reuse by an engine adapter. Exact source hashes and source-map coordinates make the artifact auditable; semantic validation rejects incomplete grids, masks, and hash drift.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tile_assembly_id", "version", "dimensions", "layered_cells", "anchors", "collision_mask", "connectors", "variations", "source", "preview_refs", "adapter_ownership"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1"] },
    "tile_assembly_id": { "type": "string", "pattern": "^TASM-[A-Z0-9-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "name": { "type": "string", "minLength": 1 },
    "dimensions": {
      "type": "object", "additionalProperties": false,
      "required": ["width", "height"],
      "properties": { "width": { "type": "integer", "minimum": 1 }, "height": { "type": "integer", "minimum": 1 } }
    },
    "layered_cells": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["x", "y", "layers"],
        "properties": {
          "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 },
          "layers": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["layer", "tile_id", "source_coordinate"],
              "properties": {
                "layer": { "type": "integer", "minimum": 0 }, "tile_id": { "type": "integer", "minimum": 0 },
                "source_coordinate": {
                  "type": "object", "additionalProperties": false,
                  "required": ["map_x", "map_y", "layer"],
                  "properties": { "map_x": { "type": "integer", "minimum": 0 }, "map_y": { "type": "integer", "minimum": 0 }, "layer": { "type": "integer", "minimum": 0 } }
                }
              }
            }
          }
        }
      }
    },
    "anchors": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["anchor_id", "role", "x", "y"],
        "properties": { "anchor_id": { "type": "string", "minLength": 1 }, "role": { "type": "string", "minLength": 1 }, "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 } }
      }
    },
    "collision_mask": {
      "type": "array", "minItems": 1,
      "items": { "type": "array", "minItems": 1, "items": { "type": "boolean" } }
    },
    "connectors": {
      "description": "Optional traversal or adjacency seams. Empty for atomic props such as trees; every supplied connector remains bounds-checked.",
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["connector_id", "type", "x", "y", "facing", "width"],
        "properties": {
          "connector_id": { "type": "string", "minLength": 1 }, "type": { "type": "string", "minLength": 1 },
          "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 },
          "facing": { "type": "string", "enum": ["north", "east", "south", "west"] }, "width": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "variations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["variation_id", "weight", "operations"],
        "properties": { "variation_id": { "type": "string", "minLength": 1 }, "weight": { "type": "integer", "minimum": 1 }, "operations": { "type": "array" } }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["owner_repo", "map_ref", "tileset_ref", "hashes"],
      "properties": {
        "owner_repo": { "type": "string", "minLength": 1 }, "map_ref": { "type": "string", "minLength": 1 }, "tileset_ref": { "type": "string", "minLength": 1 },
        "hashes": {
          "type": "object", "additionalProperties": false, "required": ["source", "map", "tileset", "tileset_images"],
          "properties": {
            "source": { "type": "object", "additionalProperties": false, "required": ["expected_sha256", "observed_sha256"], "properties": { "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "observed_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } },
            "map": { "type": "object", "additionalProperties": false, "required": ["expected_sha256", "observed_sha256"], "properties": { "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "observed_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } },
            "tileset": { "type": "object", "additionalProperties": false, "required": ["expected_sha256", "observed_sha256"], "properties": { "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "observed_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } },
            "tileset_images": {
              "type": "array", "minItems": 1,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["asset_name", "expected_sha256", "observed_sha256"],
                "properties": {
                  "asset_name": { "type": "string", "minLength": 1 },
                  "expected_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "observed_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                }
              }
            }
          }
        }
      }
    },
    "preview_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "event_overlays": {
      "description": "Optional adapter-owned event graphics required to reproduce the assembly, such as RPG Maker exterior doors that are not map-layer tiles.",
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["x", "y", "source_event_id", "source_coordinate", "character_name", "character_index", "direction", "pattern", "priority_type", "through"],
        "properties": {
          "x": { "type": "integer", "minimum": 0 }, "y": { "type": "integer", "minimum": 0 },
          "source_event_id": { "type": "integer", "minimum": 1 },
          "source_coordinate": {
            "type": "object", "additionalProperties": false, "required": ["map_x", "map_y"],
            "properties": { "map_x": { "type": "integer", "minimum": 0 }, "map_y": { "type": "integer", "minimum": 0 } }
          },
          "character_name": { "type": "string", "minLength": 1 },
          "character_index": { "type": "integer", "minimum": 0, "maximum": 7 },
          "direction": { "type": "integer", "enum": [2, 4, 6, 8] },
          "pattern": { "type": "integer", "minimum": 0, "maximum": 2 },
          "priority_type": { "type": "integer", "minimum": 0, "maximum": 2 },
          "through": { "type": "boolean" }
        }
      }
    },
    "adapter_ownership": {
      "type": "object", "additionalProperties": false, "required": ["owner_repo", "adapter_ref", "serialization_owner"],
      "properties": { "owner_repo": { "type": "string", "minLength": 1 }, "adapter_ref": { "type": "string", "minLength": 1 }, "serialization_owner": { "type": "string", "minLength": 1 } }
    }
  }
}
