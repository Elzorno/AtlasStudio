{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.example/schemas/map_vision.schema.json",
  "title": "MapVision",
  "description": "Engine-neutral, authority-labeled visual brief between Atlas canon/MapIntent and spatial generation. It describes what a map must communicate without coordinates, raw engine IDs, or self-authorized canon.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "map_vision_id", "version", "status", "atlas_screen_id",
    "map_intent_ref", "title", "emotional_read", "memorable_identity",
    "geography", "first_view", "landmarks", "building_silhouettes",
    "materials", "color_language", "roads_and_circulation", "density",
    "environmental_storytelling", "story_state_variants", "canon_anchors",
    "exclusions", "source_provenance", "approval"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1"] },
    "map_vision_id": { "type": "string", "pattern": "^MV-[A-Z0-9-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "status": { "type": "string", "enum": ["draft", "pending_human_approval", "approved", "rejected", "superseded"] },
    "atlas_screen_id": { "type": "string", "pattern": "^SCR-[A-Z0-9-]+$" },
    "map_intent_ref": { "type": "string", "pattern": "^MI-[A-Z0-9-]+@[0-9]+\\.[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "emotional_read": { "$comment": "Ordered first-impression beats.", "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "memorable_identity": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } },
    "geography": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "first_view": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "landmarks": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["landmark_id", "role", "description", "authority", "confidence", "source_refs"], "properties": { "landmark_id": { "type": "string", "pattern": "^LM-[A-Z0-9-]+$" }, "role": { "type": "string", "enum": ["dominant", "supporting", "background"] }, "description": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "building_silhouettes": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["building_role", "scale", "height_profile", "shape_language", "variation_rules", "authority", "confidence", "source_refs"], "properties": { "building_role": { "type": "string", "minLength": 1 }, "scale": { "type": "string", "enum": ["small", "medium", "large", "landmark"] }, "height_profile": { "type": "string", "minLength": 1 }, "shape_language": { "type": "string", "minLength": 1 }, "variation_rules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "materials": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "color_language": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "roads_and_circulation": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["statement_id", "text", "authority", "confidence", "source_refs"], "properties": { "statement_id": { "type": "string", "pattern": "^ST-[A-Z0-9-]+$" }, "text": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "density": { "type": "object", "additionalProperties": false, "required": ["overall", "negative_space", "zones", "authority", "confidence", "source_refs"], "properties": { "overall": { "type": "string", "enum": ["sparse", "moderate", "dense"] }, "negative_space": { "type": "string", "minLength": 1 }, "zones": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["zone_role", "density", "purpose"], "properties": { "zone_role": { "type": "string", "minLength": 1 }, "density": { "type": "string", "enum": ["sparse", "moderate", "dense"] }, "purpose": { "type": "string", "minLength": 1 } } } }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } },
    "environmental_storytelling": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["story_signal", "visual_expression", "authority", "confidence", "source_refs"], "properties": { "story_signal": { "type": "string", "minLength": 1 }, "visual_expression": { "type": "string", "minLength": 1 }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "story_state_variants": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["state_id", "trigger_ref", "visual_changes", "authority", "confidence", "source_refs"], "properties": { "state_id": { "type": "string", "pattern": "^STATE-[A-Z0-9-]+$" }, "trigger_ref": { "type": "string", "minLength": 1 }, "visual_changes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "confidence": { "type": "string", "enum": ["verified", "approved", "provisional", "speculative"] }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "canon_anchors": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["anchor_id", "requirement", "source_refs"], "properties": { "anchor_id": { "type": "string", "pattern": "^CA-[A-Z0-9-]+$" }, "requirement": { "type": "string", "minLength": 1 }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "exclusions": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["exclusion_id", "description", "reason", "source_refs"], "properties": { "exclusion_id": { "type": "string", "pattern": "^EX-[A-Z0-9-]+$" }, "description": { "type": "string", "minLength": 1 }, "reason": { "type": "string", "minLength": 1 }, "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
    "concept_direction": { "type": "object", "additionalProperties": false, "required": ["status", "artifact_refs", "use_policy"], "properties": { "status": { "type": "string", "enum": ["not_created", "pending_review", "approved_direction", "rejected"] }, "artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "use_policy": { "type": "string", "enum": ["visual_direction_only_not_structural_evidence"] } } },
    "source_provenance": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["source_ref", "source_type", "authority", "revision"], "properties": { "source_ref": { "type": "string", "minLength": 1 }, "source_type": { "type": "string", "enum": ["atlas_canon", "atlas_technical", "human_direction", "academy_reference", "concept_art"] }, "authority": { "type": "string", "enum": ["required_canon", "approved_visual_direction", "preference", "optional_inspiration"] }, "revision": { "type": "string", "minLength": 1 } } } },
    "approval": { "type": "object", "additionalProperties": false, "required": ["canon_reconciled", "unresolved_conflicts", "approved_by", "approved_at"], "properties": { "canon_reconciled": { "type": "boolean" }, "unresolved_conflicts": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["conflict_id", "statement_refs", "question_for_human"], "properties": { "conflict_id": { "type": "string", "pattern": "^CONFLICT-[A-Z0-9-]+$" }, "statement_refs": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } }, "question_for_human": { "type": "string", "minLength": 1 } } } }, "approved_by": { "type": ["string", "null"] }, "approved_at": { "type": ["string", "null"] } } }
  }
}
